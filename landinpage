    if(r.top<window.innerHeight) el.classList.add('on');
  });
});
(function(){
  var els=document.querySelectorAll('.rv');
  if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('on');});return;}
  var io=new IntersectionObserver(function(entries){
    entries.forEach(function(e){if(e.isIntersecting){e.target.classList.add('on');io.unobserve(e.target);}}); 
  },{threshold:0.05,rootMargin:'0px 0px -20px 0px'});
  els.forEach(function(el){io.observe(el);});
  setTimeout(function(){els.forEach(function(el){if(!el.classList.contains('on'))el.classList.add('on');});},1500);
})();

