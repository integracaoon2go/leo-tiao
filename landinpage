.cbanner{background:var(--teal-800);padding:var(--space-7) var(--pad-x);position:relative;overflow:hidden;border-top:3px solid var(--ouro-500);border-bottom:3px solid var(--ouro-500)}
.cbanner::after{content:'';position:absolute;right:-80px;top:-80px;width:480px;height:480px;background:radial-gradient(circle,rgba(235,177,3,.12) 0%,transparent 65%)}
.cb-in{position:relative;z-index:1;max-width:var(--max-w);margin-inline:auto;display:flex;align-items:center;justify-content:space-between;gap:var(--space-5);flex-wrap:wrap}
.cb-in h2{color:var(--white);font-size:clamp(1.8rem,3.5vw,2.6rem)}
.cb-in h2 em{color:var(--ouro-400)}
.cb-in p{font-size:var(--text-base);color:rgba(255,255,255,.65);line-height:1.6;margin-top:var(--space-1)}
.cb-live{display:flex;align-items:center;gap:7px;font-size:var(--text-xs);font-weight:600;color:rgba(255,255,255,.5);margin-top:var(--space-2)}
.cb-acts{display:flex;align-items:center;gap:var(--space-2);flex-wrap:wrap;flex-shrink:0}
.cta-wpp-subtle{display:flex;align-items:center;gap:8px;color:rgba(255,255,255,.6);font-size:var(--text-sm);font-weight:600;transition:color .2s}
.cta-wpp-subtle:hover{color:rgba(255,255,255,.88)}
.cta-col-actions{display:flex;flex-direction:column;align-items:flex-start;gap:var(--space-2)}

/* CATÁLOGO */
.cat{padding-block:var(--space-8);background:var(--stone-50)}
.cat-hd{display:flex;align-items:flex-end;justify-content:space-between;margin-bottom:var(--space-5);gap:var(--space-3);flex-wrap:wrap}
.cat-grid{display:grid;grid-template-columns:repeat(4,1fr);gap:1.25rem}
.fc{background:var(--white);border-radius:var(--r-lg);overflow:hidden;box-shadow:var(--sh-s);border:1px solid var(--stone-100);transition:all .38s cubic-bezier(.34,1.15,.64,1);cursor:pointer}
.fc:hover{transform:translateY(-8px);box-shadow:var(--sh-xl);border-color:rgba(5,72,78,.15)}
.fc-th{position:relative;overflow:hidden;height:190px}
.fc-th img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease}
.fc:hover .fc-th img{transform:scale(1.1)}
.fc-veil{position:absolute;inset:0;background:linear-gradient(to top,rgba(6,22,14,.75) 0%,transparent 55%);opacity:0;transition:opacity .3s;display:flex;align-items:flex-end;padding:12px}
.fc:hover .fc-veil{opacity:1}
.fc-vcta{display:flex;align-items:center;gap:6px;background:var(--ouro-500);color:var(--teal-900);padding:7px 14px;border-radius:100px;font-size:var(--text-xs);font-weight:700;letter-spacing:.08em;text-transform:uppercase}
.fc-og{position:absolute;top:10px;right:10px;background:rgba(255,255,255,.92);backdrop-filter:blur(8px);color:var(--teal-700);font-size:var(--text-xs);font-weight:700;padding:4px 9px;border-radius:100px;letter-spacing:.1em;text-transform:uppercase}
.fc-b{padding:1.15rem 1.2rem}
.fc-nm{font-family:var(--font-display);font-size:var(--text-lg);font-weight:700;color:var(--teal-700);letter-spacing:-.01em;margin-bottom:.2rem;line-height:1.1}
.fc-vr{font-size:var(--text-xs);color:var(--stone-400);font-weight:600;margin-bottom:.6rem}
.fc-ds{font-size:var(--text-xs);color:var(--stone-600);line-height:1.58;padding-top:.65rem;border-top:1px solid var(--stone-100)}
.cat-bot{margin-top:var(--space-5);background:var(--white);border-radius:var(--r-xl);border:1px solid var(--stone-100);box-shadow:var(--sh-s);padding:var(--space-4) var(--space-5);display:flex;align-items:center;justify-content:space-between;gap:var(--space-4);flex-wrap:wrap}
.cat-bot h3{margin-bottom:.2rem}
.cat-bot p{font-size:var(--text-sm);color:var(--stone-400)}
.urg-line{display:flex;align-items:center;gap:6px;font-size:var(--text-xs);font-weight:600;color:var(--teal-600);margin-top:.35rem}
.cat-bot-right{display:flex;flex-direction:column;align-items:flex-end;gap:var(--space-1)}
.cat-bot-note{font-size:var(--text-xs);color:var(--stone-400)}

/* PARCEIROS / PROVA SOCIAL */
.parceiros{background:var(--white);padding-block:var(--space-7);border-top:1px solid var(--stone-100);border-bottom:1px solid var(--stone-100)}
.parceiros-in{max-width:var(--max-w);margin-inline:auto;padding-inline:var(--pad-x);text-align:center}
.parceiros h2{margin-bottom:.5rem}
.parceiros-sub{font-size:var(--text-sm);color:var(--stone-400);margin-bottom:var(--space-4);max-width:520px;margin-inline:auto}
.logos-grid{display:flex;align-items:center;justify-content:center;flex-wrap:wrap;gap:1.25rem 2rem}
.logo-slot{min-width:140px;height:64px;padding:12px 20px;background:var(--stone-50);border:1px dashed var(--stone-200);border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;font-size:var(--text-xs);font-weight:700;color:var(--stone-400);letter-spacing:.06em;text-transform:uppercase;transition:all .25s}
.logo-slot:hover{border-color:var(--teal-600);color:var(--teal-700);background:var(--teal-50);transform:translateY(-2px)}
.fundador-box{margin-top:var(--space-3);margin-bottom:var(--space-2);padding:var(--space-3);background:var(--teal-50);border-radius:var(--r-lg);border-left:4px solid var(--teal-700);display:flex;gap:var(--space-3);align-items:flex-start}
.fundador-av{width:72px;height:72px;border-radius:50%;background:var(--teal-700);color:var(--white);display:flex;align-items:center;justify-content:center;font-family:var(--font-display);font-size:1.5rem;font-weight:800;flex-shrink:0}
.fundador-info h4{margin-bottom:.25rem}
.fundador-info p{font-size:var(--text-sm);color:var(--stone-600);line-height:1.6}

/* DIFERENCIAIS */
.dif{padding-block:var(--space-8);background:var(--white)}
.dif-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:1.5rem;margin-top:var(--space-5)}
.dc{padding:var(--space-4);border-radius:var(--r-lg);border:1px solid var(--stone-100);position:relative;overflow:hidden;transition:all .35s cubic-bezier(.34,1.2,.64,1);cursor:default;background:var(--white)}
.dc::before{content:'';position:absolute;top:0;left:0;right:0;height:3px;background:linear-gradient(90deg,var(--teal-600),var(--verde-500));transform:scaleX(0);transform-origin:left;transition:transform .4s ease}
.dc:hover{transform:translateY(-6px);box-shadow:var(--sh-l);border-color:rgba(5,72,78,.2)}
.dc:hover::before{transform:scaleX(1)}
.di{width:52px;height:52px;background:var(--teal-50);border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;font-size:1.5rem;margin-bottom:1.2rem;border:1px solid var(--teal-100);transition:all .3s}
.dc:hover .di{background:var(--teal-700);border-color:var(--teal-700);transform:scale(1.05)}
.dc h3{margin-bottom:.6rem;font-size:var(--text-xl)}
.dc p{font-size:var(--text-base);color:var(--stone-600);line-height:1.75}
.dtag{display:inline-flex;align-items:center;gap:4px;margin-top:var(--space-2);font-size:var(--text-xs);font-weight:700;color:var(--verde-600);letter-spacing:.07em;text-transform:uppercase}

/* CREDIBILIDADE */
.cred{background:var(--teal-50);border-top:1px solid rgba(5,72,78,.1);border-bottom:1px solid rgba(5,72,78,.1);padding-block:var(--space-7)}
.cred-g{max-width:var(--max-w);margin-inline:auto;padding-inline:var(--pad-x);display:grid;grid-template-columns:repeat(3,1fr);gap:var(--space-4)}
.cc{background:var(--white);border-radius:var(--r-lg);padding:var(--space-4);display:flex;align-items:flex-start;gap:var(--space-3);border:1px solid var(--stone-100);border-bottom:3px solid var(--teal-700);box-shadow:var(--sh-s);transition:all .3s}
.cc:hover{transform:translateY(-3px);box-shadow:var(--sh-l)}
.cc-ic{width:48px;height:48px;flex-shrink:0;background:var(--teal-700);border-radius:var(--r-md);display:flex;align-items:center;justify-content:center;font-size:1.25rem}
.cc h3{margin-bottom:.3rem;font-size:var(--text-base)}
.cc p{font-size:var(--text-xs);color:var(--stone-400);line-height:1.6}

/* CONTATO */
.contato{padding-block:var(--space-8);background:var(--stone-50)}
.contato-g{display:grid;grid-template-columns:1fr 1.35fr;gap:var(--space-7);align-items:start}
.cl-intro{font-size:var(--text-base);color:var(--stone-600);line-height:1.78;margin-bottom:var(--space-4);font-weight:300}
.ub-box{background:var(--teal-50);border:1px solid rgba(5,72,78,.15);border-left:4px solid var(--teal-700);border-radius:var(--r-lg);padding:var(--space-2) var(--space-3);margin-bottom:var(--space-4);display:flex;align-items:center;gap:var(--space-2)}
.ub-title{font-size:var(--text-base);font-weight:700;color:var(--teal-700);display:block;margin-bottom:2px}
.ub-sub{font-size:var(--text-xs);color:var(--stone-400)}
.ci-list{list-style:none;margin-bottom:var(--space-4)}
.ci{display:flex;align-items:center;gap:var(--space-2);padding:.85rem 0;border-bottom:1px solid var(--stone-100)}
.ci:last-child{border-bottom:none}
.ci-ico{width:42px;height:42px;background:var(--teal-50);border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-size:1rem;flex-shrink:0;border:1px solid var(--teal-100)}
.ci-m{font-weight:600;font-size:var(--text-base);color:var(--stone-900)}
.ci-s{font-size:var(--text-xs);color:var(--stone-400);margin-top:1px}
.wpp-note{font-size:var(--text-xs);color:var(--stone-400);display:flex;align-items:center;gap:5px;margin-top:var(--space-2)}
.fw{background:var(--white);border-radius:var(--r-xl);padding:2.75rem;box-shadow:var(--sh-l);border:1px solid var(--stone-100);border-top:4px solid var(--ouro-500);position:relative}
.form-ub{position:absolute;top:-17px;left:50%;transform:translateX(-50%);background:var(--ouro-500);color:var(--teal-900);padding:5px 18px;border-radius:100px;font-size:var(--text-xs);font-weight:700;letter-spacing:.1em;text-transform:uppercase;box-shadow:var(--sh-a);white-space:nowrap;display:flex;align-items:center;gap:6px}
.form-ub-dot{width:7px;height:7px;background:var(--ouro-400);border-radius:50%;animation:blink 1.5s ease infinite;flex-shrink:0;display:block}
.form-title{font-size:var(--text-xl);margin-top:var(--space-2)}
.form-sub{font-size:var(--text-sm);color:var(--stone-400);margin-bottom:1.6rem;line-height:1.5}
.fr{display:grid;grid-template-columns:1fr 1fr;gap:.85rem}
.fg{margin-bottom:.85rem}
.fg label{display:block;font-size:var(--text-xs);font-weight:700;letter-spacing:.12em;text-transform:uppercase;color:var(--stone-800);margin-bottom:5px}
.fg input,.fg select,.fg textarea{width:100%;padding:11px 13px;border:1.5px solid var(--stone-100);border-radius:var(--r-sm);font-family:var(--font-body);font-size:var(--text-base);color:var(--stone-900);background:var(--stone-50);transition:all .2s;outline:none}
.fg input:focus,.fg select:focus,.fg textarea:focus{border-color:var(--teal-600);background:var(--white);box-shadow:0 0 0 3px rgba(5,72,78,.08)}
.fg textarea{resize:vertical;min-height:100px}
.btn-sub{width:100%;padding:16px;background:var(--ouro-500);color:var(--teal-900);border:none;border-radius:var(--r-sm);font-family:var(--font-body);font-size:var(--text-base);font-weight:800;letter-spacing:.03em;cursor:pointer;display:flex;align-items:center;justify-content:center;gap:9px;transition:all .3s cubic-bezier(.34,1.3,.64,1);margin-top:.3rem;box-shadow:var(--sh-a)}
.btn-sub:hover{background:var(--ouro-400);transform:translateY(-2px);box-shadow:0 16px 44px rgba(235,177,3,.5)}
.form-note{text-align:center;font-size:var(--text-xs);color:var(--stone-400);margin-top:var(--space-2);display:flex;align-items:center;justify-content:center;gap:6px}

/* LOCALIZAÇÃO */
.loc{padding-block:var(--space-7);background:var(--white)}
.loc-hd-row{display:flex;align-items:flex-end;justify-content:space-between;gap:var(--space-4);flex-wrap:wrap;margin-top:var(--space-2);margin-bottom:var(--space-5)}
.loc-grid{display:grid;grid-template-columns:1fr 380px;gap:var(--space-4);align-items:stretch}
.loc-map{position:relative;border-radius:var(--r-xl);overflow:hidden;box-shadow:var(--sh-xl);border:2px solid var(--teal-100);height:460px;background:var(--stone-50)}
.loc-map iframe{position:absolute;inset:0;width:100%;height:100%}
.map-pin{position:absolute;bottom:20px;left:20px;z-index:2;pointer-events:none}
.map-card{background:rgba(255,255,255,.96);backdrop-filter:blur(12px);border-radius:var(--r-md);padding:10px 14px;display:flex;align-items:center;gap:10px;box-shadow:var(--sh-l);border:1px solid var(--stone-100);border-left:3px solid var(--teal-700)}
.map-pin-ico{font-size:var(--text-lg)}
.mc-nm{font-weight:700;font-size:var(--text-sm);color:var(--teal-700)}
.mc-ad{font-size:var(--text-xs);color:var(--stone-400);margin-top:1px}
.loc-info{display:flex;flex-direction:column;gap:var(--space-2)}
.lac{background:var(--teal-50);border:1px solid rgba(5,72,78,.12);border-radius:var(--r-lg);padding:var(--space-3);display:flex;align-items:flex-start;gap:var(--space-2)}
.lac-icon-lg{font-size:1.8rem;flex-shrink:0;margin-top:.1rem}
.lac-lbl{font-size:var(--text-xs);font-weight:700;letter-spacing:.15em;text-transform:uppercase;color:var(--ouro-600);margin-bottom:.3rem}
.lac-val{font-weight:700;font-size:var(--text-xl);color:var(--teal-700);letter-spacing:-.01em;line-height:1.2}
.lac-city{font-size:var(--text-sm);color:var(--stone-400);margin-top:.2rem;font-weight:500}
.lhi{background:var(--stone-50);border:1px solid var(--stone-100);border-radius:var(--r-lg);padding:var(--space-3);display:flex;align-items:flex-start;gap:var(--space-2)}
.loc-icon-md{font-size:1.5rem;flex-shrink:0}
.lhi-t{font-weight:700;font-size:var(--text-base);color:var(--teal-700);margin-bottom:.3rem}
.lhi-p{font-size:var(--text-xs);color:var(--stone-600);line-height:1.6}
.loc-ctas{display:flex;gap:var(--space-2);flex-wrap:wrap}
.loc-sub{font-size:var(--text-base);color:var(--stone-600);margin-top:var(--space-1);font-weight:300;line-height:1.7}

/* FOOTER */
footer{background:var(--teal-900);padding:var(--space-8) var(--pad-x) var(--space-4);border-top:4px solid var(--ouro-500)}
.footer-grid{max-width:var(--max-w);margin-inline:auto;display:grid;grid-template-columns:2fr 1fr 1fr 1fr;gap:var(--space-6);padding-bottom:var(--space-6);border-bottom:1px solid rgba(255,255,255,.07)}
.fb-logo{height:66px;width:66px;object-fit:contain;margin-bottom:var(--space-2);filter:brightness(1.08)}
.fb-nm{font-family:var(--font-display);font-size:var(--text-xl);font-weight:700;color:var(--white);margin-bottom:.3rem}
.fb-tag{font-style:italic;font-size:var(--text-xs);color:rgba(255,255,255,.35);margin-bottom:var(--space-2);line-height:1.5}
.fb-ds{font-size:var(--text-xs);color:rgba(255,255,255,.46);line-height:1.72;margin-bottom:var(--space-3)}
.fsoc{display:flex;gap:.4rem}
.fsb{width:36px;height:36px;background:rgba(255,255,255,.055);border:1px solid rgba(255,255,255,.09);border-radius:var(--r-sm);display:flex;align-items:center;justify-content:center;font-size:.88rem;transition:all .2s}
.fsb:hover{background:rgba(235,177,3,.2);border-color:rgba(235,177,3,.4)}
.fc2 h4{font-size:var(--text-xs);font-weight:700;letter-spacing:.2em;text-transform:uppercase;color:var(--ouro-400);margin-bottom:1.15rem}
.fc2 ul{list-style:none}
.fc2 ul li{margin-bottom:.5rem}
.fc2 ul li a{font-size:var(--text-sm);color:rgba(255,255,255,.44);transition:color .2s}
.fc2 ul li a:hover{color:rgba(255,255,255,.88)}
.fbot{max-width:var(--max-w);margin:2.25rem auto 0;display:flex;justify-content:space-between;align-items:center;font-size:var(--text-xs);color:rgba(255,255,255,.22);flex-wrap:wrap;gap:.75rem}
.fcerts{display:flex;gap:.5rem}
.fcert{background:rgba(255,255,255,.04);border:1px solid rgba(255,255,255,.07);padding:3px 9px;border-radius:5px;font-size:.6rem;font-weight:700;letter-spacing:.07em;text-transform:uppercase;color:rgba(255,255,255,.26)}
.footer-frase{font-style:italic;color:rgba(255,255,255,.18)}

/* MODAL CATÁLOGO */
/* ── CATÁLOGO PÁGINA COMPLETA ─────────────────────────────────────────────── */
.modal-overlay{display:none;position:fixed;inset:0;z-index:9998;background:var(--white);overflow-y:auto;-webkit-overflow-scrolling:touch}
.modal-overlay.active{display:block}
.modal-box{width:100%;max-width:100%;min-height:100vh;display:flex;flex-direction:column}
.modal-header{display:flex;align-items:center;justify-content:space-between;padding:1rem 1.25rem;border-bottom:3px solid var(--ouro-500);background:var(--teal-700);position:sticky;top:0;z-index:10;gap:.75rem}
.modal-eyebrow{display:none}
.modal-title{font-family:var(--font-display);font-size:1.25rem;font-weight:700;color:white;letter-spacing:-.01em;line-height:1.2}
.modal-sub{font-size:.7rem;color:rgba(255,255,255,.6);margin-top:2px}
.modal-close{background:rgba(255,255,255,.15);border:1.5px solid rgba(255,255,255,.3);cursor:pointer;width:42px;height:42px;border-radius:50%;font-size:1.1rem;color:white;display:flex;align-items:center;justify-content:center;flex-shrink:0;transition:all .2s}
.modal-close:hover{background:rgba(255,255,255,.3)}
.modal-grid{display:flex;flex-direction:column;gap:0;padding:0;flex:1}
.mc-card{display:flex;align-items:center;gap:1rem;padding:.9rem 1.25rem;border-bottom:1px solid var(--stone-100);background:white;transition:background .2s}
.mc-card:hover{background:var(--stone-50)}
.mc-card:active{background:var(--teal-50)}
.mc-img-wrap{width:72px;height:72px;flex-shrink:0;border-radius:10px;overflow:hidden;border:1px solid var(--stone-100)}
.mc-img-wrap img{width:100%;height:100%;object-fit:cover}
.mc-info{flex:1;min-width:0}
.mc-name{font-family:var(--font-display);font-size:1.05rem;font-weight:700;color:var(--teal-700);line-height:1.2}
.mc-origin{font-size:.68rem;color:var(--stone-400);font-weight:500;margin-top:2px}
.mc-wpp{display:flex;align-items:center;justify-content:center;width:42px;height:42px;background:var(--wpp-green);border-radius:50%;flex-shrink:0;transition:transform .2s}
.mc-wpp:hover{transform:scale(1.1)}
.mc-wpp svg{width:20px;height:20px;fill:white}
.modal-footer{border-top:3px solid var(--ouro-500);padding:1.5rem 1.25rem;text-align:center;background:var(--teal-700);display:flex;flex-direction:column;align-items:center;gap:.75rem}
.modal-footer p{font-size:var(--text-sm);color:rgba(255,255,255,.75)}
.modal-footer .btn{width:100%;max-width:360px;justify-content:center}

/* RESPONSIVE */
/* ── TABLET ──────────────────────────────────────────────────────────────── */
@media(max-width:1100px){
  .cat-grid{grid-template-columns:repeat(2,1fr)}
  .dif-grid{grid-template-columns:repeat(2,1fr)}
  .footer-grid{grid-template-columns:1fr 1fr;gap:var(--space-4)}
}

/* ── MOBILE LANDSCAPE / SMALL TABLET ─────────────────────────────────────── */
@media(max-width:860px){
  .hero-lay{grid-template-columns:1fr;padding:5rem var(--pad-x) 4rem}
  .hero-panel{display:none}
  .sobre-grid{grid-template-columns:1fr;gap:var(--space-5)}
  .sobre-fc{right:10px;bottom:10px}
  .nums-g{grid-template-columns:repeat(2,1fr);gap:var(--space-4)}
  .nums-g .ni+.ni{border-left:none}
  .contato-g{grid-template-columns:1fr;gap:var(--space-5)}
  .cb-in{flex-direction:column;text-align:center}
  .cb-acts{justify-content:center}
  .fr{grid-template-columns:1fr}
  .loc-grid{grid-template-columns:1fr}
  .loc-map{height:320px}
  .loc-hd-row{flex-direction:column;align-items:flex-start}
  .cred-g{grid-template-columns:1fr}
  h2,.h2{font-size:clamp(1.6rem,4vw,2.2rem)}
}

/* ── MOBILE ───────────────────────────────────────────────────────────────── */
@media(max-width:600px){
  /* Globals */
  :root{
    --pad-x: 1rem;
    --space-5: 2rem;
    --space-6: 2.5rem;
    --space-7: 3rem;
    --space-8: 4rem;
  }
  body{font-size:.92rem}

  /* Header */
  .topbar{display:none}
  .hinner{height:60px;padding-inline:.75rem}
  .logo img{height:42px;width:42px}
  .logo-name{font-size:.95rem}
  .logo-sub{display:none}
  nav .nl{display:none}
  nav .nsep{display:none}
